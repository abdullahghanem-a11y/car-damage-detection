    {
      "name": "Detection",
      "item": [
        {
          "name": "Detect Damage — Single Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Status is 200",
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Response has car_groups",
                  "pm.test(\"Has car_groups\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.car_groups).to.be.an(\"array\");",
                  "});",
                  "",
                  "// Test 3: At least one verified image",
                  "pm.test(\"Has verified images\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.verified_images).to.be.above(0);",
                  "});",
                  "",
                  "// Test 4: Car detected",
                  "pm.test(\"Car was detected\", function () {",
                  "    const json = pm.response.json();",
                  "    const group = json.car_groups[0];",
                  "    pm.expect(group.vehicle_type).to.equal(\"car\");",
                  "});",
                  "",
                  "// Test 5: Detections have severity",
                  "pm.test(\"Detections have severity labels\", function () {",
                  "    const json = pm.response.json();",
                  "    const detections = json.car_groups[0].images[0].detections;",
                  "    pm.expect(detections).to.be.an(\"array\");",
                  "    pm.expect(detections[0].severity_label).to.be.oneOf([\"Minor\", \"Moderate\", \"Severe\"]);",
                  "});",
                  "",
                  "// Test 6: Aggregated damage exists",
                  "pm.test(\"Has aggregated damage\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.car_groups[0].aggregated_damage).to.be.an(\"array\");",
                  "});",
                  "",
                  "// Test 7: Overall severity exists",
                  "pm.test(\"Has overall severity\", function () {",
                  "    const json = pm.response.json();",
                  "    const severity = json.car_groups[0].overall_severity;",
                  "    pm.expect(severity.label).to.be.oneOf([\"Minor\", \"Moderate\", \"Severe\"]);",
                  "});",
                  "",
                  "// Auto-save detection ID for history tests",
                  "pm.test(\"Save detection ID\", function () {",
                  "    const json = pm.response.json();",
                  "    if (json.car_groups.length > 0) {",
                  "        pm.collectionVariables.set(\"detection_id\", 1);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
