# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/cardd

# ── Model ─────────────────────────────────────
HF_REPO_ID=abdullahg7/cardd-yolov8s
MODEL_VERSION=v1.0/best.pt
MODEL_CACHE_DIR=./weights

# ── Inference ─────────────────────────────────
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45
IMG_SIZE=640
DEVICE=0

# ── Upload ────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png