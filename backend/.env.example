# Database
DATABASE_URL=postgresql://user:password@localhost:5432/autops

# YOLO Model
HF_REPO_ID=abdullahg7/cardd-yolov8s
MODEL_VERSION=v2.0/best.pt
MODEL_CACHE_DIR=./weights
UPLOADS_DIR=uploads
CONF_THRESHOLD=0.35
IOU_THRESHOLD=0.45
IMG_SIZE=640
DEVICE=0

# Auth — CHANGE ALL OF THESE IN PRODUCTION
SECRET_KEY=your_super_secret_key_min_32_chars
REFRESH_SECRET_KEY=your_refresh_secret_key_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin credentials — CHANGE THESE
ADMIN_EMAIL=admin@autops.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=