    {
      "name": "Detection",
      "item": [
        {
          "name": "Detect Damage",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Has session_id', () => pm.expect(res.session_id).to.be.a('number'));",
            "pm.test('Has car_groups', () => pm.expect(res.car_groups).to.be.an('array'));",
            "pm.collectionVariables.set('session_id', res.session_id);",
            "if (res.car_groups.length > 0 && res.car_groups[0].images.length > 0) {",
            "  pm.collectionVariables.set('detection_id', res.car_groups[0].images[0].id || 1);",
            "}",
            "console.log('Session ID:', res.session_id, '| Instances:', res.total_instances);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "files", "type": "file", "description": "Car image (jpg/jpeg/png, max 10MB)" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/detect/?session_name=Test Session",
              "host": ["{{base_url}}"], "path": ["api","detect",""],
              "query": [{ "key": "session_name", "value": "Test Session", "description": "Required. Name for this detection session." }]
            },
            "description": "Detect car damage in uploaded images.\n\nRequirements:\n- session_name query param is required\n- Max 10 images per request\n- Supported: jpg, jpeg, png, max 10MB each\n- Bearer token required\n\nOn success: session_id and detection_id auto-saved."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "{\n  \"session_id\": 1,\n  \"session_name\": \"Test Session\",\n  \"total_images\": 1,\n  \"verified_images\": 1,\n  \"rejected_images\": [],\n  \"total_instances\": 3,\n  \"car_groups\": [\n    {\n      \"vehicle_type\": \"car\",\n      \"image_count\": 1,\n      \"total_instances\": 3,\n      \"overall_severity\": { \"label\": \"Moderate\", \"score\": 0.54, \"color\": \"#f59e0b\" },\n      \"aggregated_damage\": [\n        { \"class_name\": \"dent\", \"count\": 2, \"severity_label\": \"Moderate\", \"max_confidence\": 0.82 }\n      ],\n      \"images\": [\n        {\n          \"filename\": \"car.jpg\",\n          \"verified\": true,\n          \"vehicle_type\": \"car\",\n          \"total_instances\": 3,\n          \"detections\": [\n            { \"class_id\": 0, \"class_name\": \"dent\", \"confidence\": 0.82, \"bbox\": [120, 80, 340, 220], \"severity_label\": \"Moderate\", \"severity_score\": 0.54, \"severity_color\": \"#f59e0b\" }\n          ],\n          \"annotated_image\": \"<base64>\",\n          \"overall_severity\": { \"label\": \"Moderate\", \"score\": 0.54 }\n        }\n      ]\n    }\n  ]\n}" },
            { "name": "400 No session_name", "status": "Bad Request", "code": 400,
              "body": "{\"detail\": \"session_name is required\"}" },
            { "name": "401 Unauthorized", "status": "Unauthorized", "code": 401,
              "body": "{\"detail\": \"Not authenticated\"}" }
          ]
        }
      ]
    },

    {
      "name": "Sessions",
      "item": [
        {
          "name": "List Sessions",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Returns array', () => pm.expect(res).to.be.an('array'));",
            "if (res.length > 0) pm.collectionVariables.set('session_id', res[0].id);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/api/sessions/?skip=0&limit=20&sort=date_desc",
              "host": ["{{base_url}}"], "path": ["api","sessions",""],
              "query": [
                { "key": "skip",     "value": "0",         "description": "Pagination offset" },
                { "key": "limit",    "value": "20",        "description": "Max results (1-100)" },
                { "key": "sort",     "value": "date_desc", "description": "date_desc|date_asc|name_asc|name_desc|severity_desc|severity_asc|instances_desc|instances_asc" },
                { "key": "search",   "value": "",          "description": "Search by session name", "disabled": true },
                { "key": "severity", "value": "",          "description": "Filter: Minor|Moderate|Severe", "disabled": true }
              ]
            },
            "description": "List all sessions for the current user.\nAdmins see all sessions across all users.\n\nSupports: search, severity filter, sort, pagination."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"Test Session\",\n    \"model_version\": \"v2.0/best.pt\",\n    \"total_instances\": 3,\n    \"overall_severity\": \"Moderate\",\n    \"image_count\": 1,\n    \"created_at\": \"2026-05-20T10:00:00Z\",\n    \"updated_at\": \"2026-05-20T10:00:00Z\"\n  }\n]" }
          ]
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/sessions/{{session_id}}", "host": ["{{base_url}}"], "path": ["api","sessions","{{session_id}}"] },
            "description": "Get a single session with all its detections and annotated images."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "{\n  \"id\": 1,\n  \"name\": \"Test Session\",\n  \"total_instances\": 3,\n  \"detections\": [ { \"id\": 1, \"image_filename\": \"car.jpg\", \"annotated_image\": \"<base64>\", \"results\": [...] } ]\n}" },
            { "name": "404 Not Found", "status": "Not Found", "code": 404,
              "body": "{\"detail\": \"Session not found\"}" }
          ]
        },
        {
          "name": "Get Raw Image",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/api/sessions/{{session_id}}/images/{{detection_id}}/raw", "host": ["{{base_url}}"], "path": ["api","sessions","{{session_id}}","images","{{detection_id}}","raw"] },
            "description": "Serve the original (unannotated) image file from disk. Returns JPEG bytes."
          },
          "response": [
            { "name": "200 Image", "status": "OK", "code": 200, "body": "<binary JPEG data>" },
            { "name": "404 Not Found", "status": "Not Found", "code": 404,
              "body": "{\"detail\": \"Raw image file not found on disk\"}" }
          ]
        },
        {
          "name": "Rename Session",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My renamed session\"\n}" },
            "url": { "raw": "{{base_url}}/api/sessions/{{session_id}}/rename", "host": ["{{base_url}}"], "path": ["api","sessions","{{session_id}}","rename"] },
            "description": "Rename a session."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "{ \"id\": 1, \"name\": \"My renamed session\", ... }" }
          ]
        },
        {
          "name": "Delete Session",
          "request": {
            "method": "DELETE", "header": [],
            "url": { "raw": "{{base_url}}/api/sessions/{{session_id}}", "host": ["{{base_url}}"], "path": ["api","sessions","{{session_id}}"] },
            "description": "Delete entire session and all its images from disk."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "{\"message\": \"Session 1 deleted successfully\"}" }
          ]
        },
        {
          "name": "Delete Selected Images",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"detection_ids\": [1, 2]\n}" },
            "url": { "raw": "{{base_url}}/api/sessions/{{session_id}}/images", "host": ["{{base_url}}"], "path": ["api","sessions","{{session_id}}","images"] },
            "description": "Delete selected images from a session. If all are deleted, the session is also removed."
          },
          "response": [
            { "name": "200 Partial Delete", "status": "OK", "code": 200,
              "body": "{\"message\": \"2 image(s) deleted\", \"session_deleted\": false, \"remaining_images\": 1}" },
            { "name": "200 Session Deleted", "status": "OK", "code": 200,
              "body": "{\"message\": \"All images deleted — session removed\", \"session_deleted\": true}" }
          ]
        },
        {
          "name": "Re-detect Image",
          "request": {
            "method": "POST", "header": [],
            "url": { "raw": "{{base_url}}/api/sessions/{{session_id}}/images/{{detection_id}}/redetect", "host": ["{{base_url}}"], "path": ["api","sessions","{{session_id}}","images","{{detection_id}}","redetect"] },
            "description": "Re-run YOLO detection on the stored raw image (after editing)."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "{\n  \"message\": \"Re-detection complete\",\n  \"total_instances\": 2,\n  \"overall_severity\": \"Minor\",\n  \"verified\": 1\n}" }
          ]
        },
        {
          "name": "Copy Detection as New",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"image_data\": \"<base64 edited image>\",\n  \"copy_name\": \"Cropped front view\"\n}" },
            "url": { "raw": "{{base_url}}/api/sessions/{{session_id}}/images/{{detection_id}}/copy", "host": ["{{base_url}}"], "path": ["api","sessions","{{session_id}}","images","{{detection_id}}","copy"] },
            "description": "Save an edited image as a new detection entry in the same session. Runs YOLO on the copy."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "{\n  \"message\": \"Copy created and re-detected successfully\",\n  \"detection_id\": 3,\n  \"total_instances\": 2,\n  \"overall_severity\": \"Minor\",\n  \"verified\": 1\n}" }
          ]
        }
      ]
    },

