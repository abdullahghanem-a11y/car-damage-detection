{
  "info": {
    "_postman_id": "7c0520aa-0032-48ef-a1bb-c725f30b0076",
    "name": "AUTOPS — Car Damage Detection API v2.0",
    "description": "Complete API collection for AUTOPS.\n\nCollection Variables:\n- base_url: http://localhost:8000\n- access_token: auto-set by login/register\n- session_id: auto-set after detection\n- detection_id: auto-set after detection\n\nWorkflow:\n1. Register or Login → access_token is auto-saved\n2. Detect Damage → session_id and detection_id auto-saved\n3. Use Sessions endpoints with saved IDs\n4. Admin endpoints require admin account",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "pm.test('API is healthy', () => pm.expect(pm.response.json().status).to.eql('healthy'));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "description": "Check if the API is running. No auth required."
          },
          "response": [{ "name": "200 OK", "status": "OK", "code": 200,
            "body": "{\"status\": \"healthy\", \"version\": \"2.0.0\"}" }]
        }
      ]
    },

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status is 201', () => pm.response.to.have.status(201));",
            "const res = pm.response.json();",
            "pm.test('Has access token', () => pm.expect(res.access_token).to.be.a('string'));",
            "pm.test('Has user object', () => pm.expect(res.user).to.be.an('object'));",
            "pm.collectionVariables.set('access_token', res.access_token);",
            "console.log('Registered as:', res.user.username);"
          ], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "description": "Register a new user account.\n\nOn success: access_token saved to collection variable automatically.\nRefresh token is set as httpOnly cookie by the server."
          },
          "response": [
            { "name": "201 Created", "status": "Created", "code": 201,
              "body": "{\n  \"access_token\": \"eyJ...\",\n  \"token_type\": \"bearer\",\n  \"user\": {\n    \"id\": 2,\n    \"email\": \"user@example.com\",\n    \"username\": \"testuser\",\n    \"role\": \"user\",\n    \"is_active\": true,\n    \"avatar_url\": null,\n    \"created_at\": \"2026-05-20T10:00:00Z\",\n    \"last_login\": null\n  }\n}" },
            { "name": "400 Email Taken", "status": "Bad Request", "code": 400,
              "body": "{\"detail\": \"Email already registered\"}" },
            { "name": "400 Username Taken", "status": "Bad Request", "code": 400,
              "body": "{\"detail\": \"Username already taken\"}" }
          ]
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Has access token', () => pm.expect(res.access_token).to.be.a('string'));",
            "pm.collectionVariables.set('access_token', res.access_token);",
            "console.log('Logged in as:', res.user.username, '| Role:', res.user.role);"
          ], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username_or_email\": \"admin\",\n  \"password\": \"Admin@AUTOPS2025\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "description": "Login with username or email.\n\nOn success: access_token saved automatically.\nRefresh token set as httpOnly cookie.\n\nDefault admin credentials:\n- username: admin\n- password: Admin@AUTOPS2025"
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "{\n  \"access_token\": \"eyJ...\",\n  \"token_type\": \"bearer\",\n  \"user\": {\n    \"id\": 1,\n    \"username\": \"admin\",\n    \"role\": \"admin\",\n    \"is_active\": true\n  }\n}" },
            { "name": "401 Invalid Credentials", "status": "Unauthorized", "code": 401,
              "body": "{\"detail\": \"Invalid credentials\"}" }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.collectionVariables.set('access_token', res.access_token);",
            "console.log('Token refreshed');"
          ], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST", "header": [],
            "url": { "raw": "{{base_url}}/api/auth/refresh", "host": ["{{base_url}}"], "path": ["api","auth","refresh"] },
            "description": "Get new access token using the httpOnly refresh cookie.\nCookie must be present (set by login/register)."
          },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200,
              "body": "{\"access_token\": \"eyJ...\", \"token_type\": \"bearer\"}" },
            { "name": "401 No Cookie", "status": "Unauthorized", "code": 401,
              "body": "{\"detail\": \"No refresh token\"}" }
          ]
        },
        {
          "name": "Get Current User",
