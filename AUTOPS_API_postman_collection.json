              "body": "{\n  \"id\": 1,\n  \"email\": \"admin@autops.com\",\n  \"username\": \"admin\",\n  \"role\": \"admin\",\n  \"is_active\": true,\n  \"avatar_url\": null,\n  \"created_at\": \"2026-05-20T10:00:00Z\",\n  \"last_login\": \"2026-05-20T12:00:00Z\"\n}" }
          ]
