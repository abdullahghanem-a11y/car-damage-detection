# ══════════════════════════════════════════════
#   Car Damage Detection — Combined .gitignore
# ══════════════════════════════════════════════

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
build/
.eggs/

# ── Environment Variables ─────────────────────
.env
.env.local
.env.production
.venv
venv/
env/
ENV/

# ── Model — Dataset (too large for GitHub) ────
model/data/images/
model/data/labels/
model/data/annotations/

# ── Model — Training Outputs ──────────────────
model/runs/
*.pt
*.pth
*.onnx
*.engine

# ── Backend — Sensitive ───────────────────────
backend/.env
backend/weights/
backend/uploads/

# ── Backend — Database ────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Frontend — Dependencies ───────────────────
frontend/node_modules/
frontend/.env
frontend/.env.local
frontend/.env.production

# ── Frontend — Build Outputs ──────────────────
frontend/dist/
frontend/dist-ssr/
frontend/build/

# ── Frontend — Logs ───────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Jupyter Notebooks ─────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ──────────────────────────────────────
*.log
logs/

# ── OS Files ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp