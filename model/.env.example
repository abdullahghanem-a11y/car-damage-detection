# ── Project Paths ─────────────────────────────
PROJECT_ROOT=C:\Users\spidy\Downloads\Damage-detection\cardd_project
DATA_DIR=${PROJECT_ROOT}\data
ANNOTATIONS_DIR=${PROJECT_ROOT}\data\annotations
IMAGES_DIR=${PROJECT_ROOT}\data\images
LABELS_DIR=${PROJECT_ROOT}\data\labels
RUNS_DIR=${PROJECT_ROOT}\runs
WEIGHTS_DIR=${PROJECT_ROOT}\runs\cardd_yolov8s3\weights

# ── Model Config ──────────────────────────────
MODEL_NAME=yolov8s.pt
BEST_MODEL=${WEIGHTS_DIR}\best.pt
YAML_PATH=${PROJECT_ROOT}\cardd.yaml

# ── Training Hyperparameters ──────────────────
EPOCHS=50
BATCH_SIZE=8
IMG_SIZE=640
DEVICE=0
PATIENCE=15
LR0=0.001
LRF=0.01
MOMENTUM=0.937
WEIGHT_DECAY=0.0005
WARMUP_EPOCHS=3.0
WARMUP_MOMENTUM=0.8
WORKERS=4

# ── Augmentation ──────────────────────────────
HSV_H=0.015
HSV_S=0.7
HSV_V=0.4
FLIPLR=0.5
MOSAIC=1.0
MIXUP=0.1
DEGREES=10.0
TRANSLATE=0.1
SCALE=0.5

# ── Inference ─────────────────────────────────
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# ── Dataset Classes ───────────────────────────
NUM_CLASSES=6
CLASS_NAMES=dent,scratch,crack,glass_shatter,lamp_broken,tire_flat